local function ensureHealthEsp(char, hum)
    local hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head")
    if not hrp or not hum then return end
    local bb = char:FindFirstChild("SynexHealthESP")
    if bb and bb:GetAttribute("Layout") ~= "right_v" then
        bb:Destroy()
        bb = nil
    end
    if not bb then
        bb = Instance.new("BillboardGui")
        bb.Name = "SynexHealthESP"
        bb.AlwaysOnTop = true
        bb.Size = UDim2.new(0, 5, 0, 48)
        bb.StudsOffset = Vector3.new(2.15, 1.15, 0) -- right side of character
        bb.MaxDistance = 5000
        bb:SetAttribute("Layout", "right_v")
        bb.Parent = char

        local bg = Instance.new("Frame")
        bg.Name = "Bg"
        bg.Size = UDim2.new(1, 0, 1, 0)
        bg.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
        bg.BackgroundTransparency = 0.2
        bg.BorderSizePixel = 0
        bg.Parent = bb
        Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

        local fill = Instance.new("Frame")
        fill.Name = "Fill"
        fill.AnchorPoint = Vector2.new(0, 1)
        fill.Position = UDim2.new(0, 0, 1, 0)
        fill.Size = UDim2.new(1, 0, 1, 0)
        fill.BackgroundColor3 = Color3.fromRGB(80, 220, 110)
        fill.BorderSizePixel = 0
        fill.Parent = bg
        Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    end
    bb.Adornee = hrp
    bb.StudsOffset = Vector3.new(2.15, 1.15, 0)
    local ratio = 0
    if hum.MaxHealth > 0 then
        ratio = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
    end
    local bg = bb:FindFirstChild("Bg")
    local fill = bg and bg:FindFirstChild("Fill")
    if fill then
        fill.Size = UDim2.new(1, 0, ratio, 0)
        if ratio > 0.55 then
            fill.BackgroundColor3 = Color3.fromRGB(80, 220, 110)
        elseif ratio > 0.25 then
            fill.BackgroundColor3 = Color3.fromRGB(240, 180, 50)
        else
            fill.BackgroundColor3 = Color3.fromRGB(230, 60, 60)
        end
    end
end

local function updESP()
    if not SynexAlive() then return end
    local anyOn = ESP_Enabled or ESP_Names or ESP_Health
    local lp = game:GetService("Players").LocalPlayer
    local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")

    for _, p in pairs(game:GetService("Players"):GetPlayers()) do
        if p ~= lp then
            local char = p.Character
            if char then
                local root = char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChildOfClass("Humanoid")
                local tooFar = false
                local dist = 0
                if root and myRoot then
                    dist = (root.Position - myRoot.Position).Magnitude
                    tooFar = dist > ESP_MaxDistance
                elseif not root or not myRoot then
                    tooFar = true
                end

                if (not anyOn) or tooFar or not hum or hum.Health <= 0 then
                    clearPlayerEspVisuals(char)
                    continue
                end

                if ESP_Enabled then
                    local hl = char:FindFirstChild("MyESP")
                    if not hl then
                        hl = Instance.new("Highlight")
                        hl.Name = "MyESP"
                        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                        hl.FillTransparency = 1
                        hl.OutlineTransparency = 0
                        hl.OutlineColor = Color3.fromRGB(115, 90, 250)
                        hl.Parent = char
                    end
                    hl.Enabled = true
                else
                    local hl = char:FindFirstChild("MyESP")
                    if hl then hl:Destroy() end
                end

                if ESP_Names then
                    ensureNameEsp(char, p, dist)
                else
                    local nameTag = char:FindFirstChild("SynexNameESP")
                    if nameTag then nameTag:Destroy() end
                end

                if ESP_Health then
                    ensureHealthEsp(char, hum)
                else
                    local hpTag = char:FindFirstChild("SynexHealthESP")
                    if hpTag then hpTag:Destroy() end
                end
            end
        end
    end
end

local function ESP_EnsureLoop()
    if espConnection then return end
    espConnection = game:GetService("RunService").Heartbeat:Connect(updESP)
end

local function ESP_StopLoopIfIdle()
    if ESP_Enabled or ESP_Names or ESP_Health then
        ESP_EnsureLoop()
        return
    end
    if espConnection then
        espConnection:Disconnect()
        espConnection = nil
    end
    for _, p in pairs(game:GetService("Players"):GetPlayers()) do
        if p.Character then
            clearPlayerEspVisuals(p.Character)
        end
    end
end

