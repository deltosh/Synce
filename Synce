local function IsValidRageTarget(player)
    if not player or player == LocalPlayer then return false end
    local enemyChar = player.Character
    local enemyHRP = enemyChar and enemyChar:FindFirstChild("HumanoidRootPart")
    local enemyHum = enemyChar and enemyChar:FindFirstChildOfClass("Humanoid")
    if not (enemyHRP and enemyHum) then return false end
    if enemyHum.Health <= 0 then return false end
    if enemyChar:FindFirstChildOfClass("ForceField") then return false end
    return true
end

function IsPlayerInsideRageFOV(player)
    if not IsValidRageTarget(player) then return false end
    local cam = workspace.CurrentCamera
    if not cam then return false end

    local targetCharacter = player.Character
    local targetPart = targetCharacter and (
        targetCharacter:FindFirstChild("HumanoidRootPart")
        or targetCharacter:FindFirstChild("UpperTorso")
        or targetCharacter:FindFirstChild("Torso")
        or targetCharacter:FindFirstChild("LowerTorso")
        or targetCharacter:FindFirstChild("Head")
    )
    if not targetPart then return false end

    local screenPos = cam:WorldToViewportPoint(targetPart.Position)
    if screenPos.Z <= 0 then return false end

    -- Locked to screen center (circle stays still)
    local center = GetRageFOVCenter()
    local pixelDist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
    return pixelDist <= (_G.__RagebotFOVRadius or 130)
end

local function GetClosestEnemy_Rage()
    local best = nil
    local bestPixel = math.huge
    local bestWorld = math.huge

    local cam = workspace.CurrentCamera
    local center = GetRageFOVCenter()
    local myChar = LocalPlayer.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP or not cam then return nil end

    local fov = _G.__RagebotFOVRadius or 130

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and IsValidRageTarget(player) then
            local char = player.Character
            local part = char:FindFirstChild("HumanoidRootPart")
                or char:FindFirstChild("UpperTorso")
                or char:FindFirstChild("Torso")
                or char:FindFirstChild("Head")
            if part then
                local screenPos = cam:WorldToViewportPoint(part.Position)
                if screenPos.Z > 0 then
                    local pixel = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if pixel <= fov then
                        local world = (myHRP.Position - part.Position).Magnitude
                        if pixel < bestPixel or (pixel == bestPixel and world < bestWorld) then
                            bestPixel = pixel
                            bestWorld = world
                            best = player
                        end
                    end
                end
            end
        end
    end
    return best
end

local function BuildRageSATarget(player)
    if not IsValidRageTarget(player) then return nil end
    local char = player.Character
    local part = char:FindFirstChild("UpperTorso")
        or char:FindFirstChild("Torso")
        or char:FindFirstChild("HumanoidRootPart")
        or char:FindFirstChild("Head")
    if not part then return nil end
    return {
        Player = player,
        Char = char,
        Part = part,
        PName = part.Name,
        Pos = part.Position,
        Dist = 0,
        WDist = 0,
    }
end

local function GetBestRageTargetPart(targetCharacter)
    if not targetCharacter then return nil end
    return targetCharacter:FindFirstChild("UpperTorso")
        or targetCharacter:FindFirstChild("Torso")
        or targetCharacter:FindFirstChild("HumanoidRootPart")
