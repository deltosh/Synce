local function RagebotLoop()
    while Ragebot_Enabled and SynexAlive() do
        local target = GetClosestEnemy_Rage()
        Ragebot_Target = target

        if Ragebot_IsReloading() then
            task.wait(0.05)
        elseif target then
            local now = tick()
            if now - Ragebot_LastShot >= Ragebot_FireGap then
                Ragebot_LastShot = now
                Shoot_Rage(target)
            end
            task.wait(0.05)
        else
            task.wait(0.08)
        end
    end
    Ragebot_Target = nil
    Ragebot_Coroutine = nil
end

