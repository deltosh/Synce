        end
    end

    RefreshCharRefs()

    local AnimTrack_Cache = nil
    local CamoAnim = Instance.new("Animation", nil);
    CamoAnim.AnimationId = "rbxassetid://215384594";

    local RS = RunService;
    local UpdateFrame = RS.Heartbeat;
    local WaitRender = RS.RenderStepped;

