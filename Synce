--[[ Synex Key Gate — do not remove ]]--
do
	local SYNEX_API = "https://synex-api.syx1.workers.dev"

	local function synexFail(msg)
		msg = tostring(msg)
		warn("[Synex] " .. msg)
		if string.find(msg, "blacklist", 1, true) then
			pcall(function()
				local lp = game:GetService("Players").LocalPlayer
				if lp then
					lp:Kick(msg)
				end
			end)
		end
		return error("[Synex] " .. msg, 0)
	end

	if type(script_key) ~= "string" or script_key == "" then
		return synexFail("script_key missing. Put script_key=\"...\" above the loader.")
	end

	local function synexHwid()
		local candidates = {
			function() return gethwid() end,
			function() return get_hwid() end,
			function() return syn and syn.get_hwid and syn.get_hwid() end,
			function() return game:GetService("RbxAnalyticsService"):GetClientId() end,
		}
		for _, fn in ipairs(candidates) do
			local ok, value = pcall(fn)
			if ok and type(value) == "string" and #value > 0 then
				return value
			end
		end
		return nil
	end

	local function synexRequest(opts)
		local req =
			(syn and syn.request)
			or (http and http.request)
			or http_request
			or request
			or (fluxus and fluxus.request)
		if not req then
			return nil, "executor missing request()"
		end
		local ok, res = pcall(req, opts)
		if not ok then
			return nil, res
		end
		return res
	end

	local hwid = synexHwid()
	if not hwid then
		return synexFail("Could not read HWID")
	end

	local HttpService = game:GetService("HttpService")
	local res, err = synexRequest({
		Url = SYNEX_API .. "/v1/verify",
		Method = "POST",
		Headers = { ["Content-Type"] = "application/json" },
		Body = HttpService:JSONEncode({ key = script_key, hwid = hwid }),
	})
	if not res then
		return synexFail(err or "verify request failed")
	end

	local status = res.StatusCode or res.Status or 0
	local body = res.Body or res.body or ""
	local decoded
	do
		local ok, data = pcall(function()
			return HttpService:JSONDecode(body)
		end)
		if not ok then
			return synexFail("Invalid verify response")
		end
		decoded = data
	end

	if status ~= 200 or not decoded or not decoded.ok then
		return synexFail((decoded and decoded.error) or ("Key verify failed (" .. tostring(status) .. ")"))
	end
end
--[[ End Synex Key Gate ]]--

