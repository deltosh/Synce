local function Shoot_Rage(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return end
    if Ragebot_IsReloading() then return end
    if Ragebot_ShootBusy then return end

    local myChar = LocalPlayer.Character
    local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local enemyChar = targetPlayer.Character
    local enemyHrp = enemyChar and enemyChar:FindFirstChild("HumanoidRootPart")
    local enemyAim = enemyChar and (
        enemyChar:FindFirstChild("UpperTorso")
        or enemyChar:FindFirstChild("Torso")
        or enemyChar:FindFirstChild("Head")
        or enemyHrp
    )
    if not (myHrp and enemyHrp and enemyAim) then
        Ragebot_ClickMouse()
        return
    end

    Ragebot_ShootBusy = true
    local ok, err = pcall(function()
        if Ragebot_WallbangOn() then
            -- Under-target wallbang (no metamethod hooks — AC watches those)
            local cam = workspace.CurrentCamera
            local savedCF = myHrp.CFrame
            local savedVel = myHrp.AssemblyLinearVelocity
            local savedCam = cam and cam.CFrame
            local underPos = enemyHrp.Position - Vector3.new(0, 3.2, 0)
            local lookAt = enemyAim.Position
            local shootCF = CFrame.lookAt(underPos, lookAt)

            myHrp.AssemblyLinearVelocity = Vector3.zero
            myHrp.CFrame = shootCF
            if cam then
                -- Aim camera at target so the real gun ray hits them
                cam.CFrame = CFrame.lookAt(underPos + Vector3.new(0, 1.4, 0), lookAt)
            end
            RunService.Heartbeat:Wait()
            Ragebot_ClickMouse()
            local weapon = GetEquippedWeapon()
            if weapon and weapon:IsA("Tool") then
                pcall(function()
                    weapon:Activate()
                end)
            end
            task.wait(0.06)
            if myHrp and myHrp.Parent then
                myHrp.CFrame = savedCF
                myHrp.AssemblyLinearVelocity = savedVel
            end
            if cam and savedCam then
                cam.CFrame = savedCam
            end
        else
            Ragebot_ClickMouse()
        end
    end)
    Ragebot_ShootBusy = false
    if not ok then
        warn("Ragebot shoot error:", err)
    end
end

local function RagebotEspLoop()
    if Ragebot_EspConn then
        Ragebot_EspConn:Disconnect()
        Ragebot_EspConn = nil
    end
    Ragebot_EspConn = RunService.RenderStepped:Connect(function()
