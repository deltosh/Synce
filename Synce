SkinChanger_UserId = ""
local SkinChanger_ActiveId = nil -- last successfully applied skin (re-applied on respawn)
SkinChanger_Saved = {}
local SkinChanger_SaveFile = "Synex_SavedDisguises.json"
local SkinChanger_Applying = false

local function SkinChanger_Notify(title, text)
    pcall(function()
        game.StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = 4,
        })
    end)
end

local function SkinChanger_SaveToFile()
    if not writefile then return end
    local HttpService = game:GetService("HttpService")
    local ok, encoded = pcall(function()
        return HttpService:JSONEncode(SkinChanger_Saved)
    end)
    if ok then
        pcall(writefile, SkinChanger_SaveFile, encoded)
    end
end

local function SkinChanger_LoadFromFile()
    if not isfile or not readfile then return end
    if not isfile(SkinChanger_SaveFile) then return end
    local HttpService = game:GetService("HttpService")
    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(readfile(SkinChanger_SaveFile))
    end)
    if ok and type(decoded) == "table" then
        SkinChanger_Saved = decoded
    end
end

SkinChanger_Apply = function(userId, notifyName, silent)
    local userIdNum = tonumber(userId)
    if not userIdNum then
        if not silent then
            SkinChanger_Notify("Disguise", "UserId를 숫자로 입력하세요!")
        end
        return false
    end

    local character = LocalPlayer.Character
    if not character then
        if not silent then
            SkinChanger_Notify("Disguise", "캐릭터가 없습니다.")
        end
        return false
    end

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then
        if not silent then
            SkinChanger_Notify("Disguise", "살아 있는 캐릭터에서만 사용할 수 있습니다.")
        end
        return false
    end

    if SkinChanger_Applying then
        return false
    end
    SkinChanger_Applying = true

    local function finish(okResult)
        SkinChanger_Applying = false
        if okResult then
            SkinChanger_ActiveId = userIdNum
            SkinChanger_UserId = tostring(userIdNum)
            if not silent then
                SkinChanger_Notify("Disguise", (notifyName or tostring(userIdNum)) .. " 외형으로 변경됨!")
            end
        end
        return okResult
    end

    -- Prefer modern description API (no character unparent / no fake death)
    do
        local okDesc, desc = pcall(function()
            return Players:GetHumanoidDescriptionFromUserIdAsync(userIdNum)
        end)
        if okDesc and desc then
            local okApply = pcall(function()
                humanoid:ApplyDescription(desc)
            end)
            if okApply then
                return finish(true)
            end
        end
    end

    -- Fallback: cosmetic-only morph. Never set character.Parent = nil (that kills / blocks respawn).
    local ok, appearanceModel = pcall(function()
        return Players:GetCharacterAppearanceAsync(userIdNum)
    end)

    if not ok or not appearanceModel then
        SkinChanger_Applying = false
        if not silent then
            SkinChanger_Notify("Disguise", "외형 로드 실패: " .. tostring(userIdNum))
        end
        return false
    end

    for _, inst in ipairs(character:GetChildren()) do
        if inst:IsA("Accessory")
            or inst:IsA("Shirt")
            or inst:IsA("Pants")
            or inst:IsA("BodyColors")
            or inst:IsA("ShirtGraphic") then
            inst:Destroy()
        end
    end

    local head = character:FindFirstChild("Head")
    if head then
        for _, inst in ipairs(head:GetChildren()) do
            if inst:IsA("SpecialMesh") and inst:GetAttribute("FromMorph") == true then
                inst:Destroy()
            end
            if inst:IsA("Decal") and (inst.Name == "face" or inst.Name == "Face") then
                inst:Destroy()
            end
        end
    end

    for _, inst in ipairs(appearanceModel:GetChildren()) do
        if inst:IsA("Shirt")
            or inst:IsA("Pants")
            or inst:IsA("BodyColors")
            or inst:IsA("ShirtGraphic") then
            local clone = inst:Clone()
            clone.Parent = character
        elseif inst:IsA("Accessory") then
            local clone = inst:Clone()
            clone.Name = "#ACCESSORY_" .. clone.Name
            local added = false
            pcall(function()
                humanoid:AddAccessory(clone)
                added = clone.Parent ~= nil
            end)
            if not added then
                clone.Parent = character
            end
        elseif inst:IsA("SpecialMesh") and head then
            local clone = inst:Clone()
            clone:SetAttribute("FromMorph", true)
            clone.Parent = head
        elseif inst.Name == "R6" and humanoid.RigType == Enum.HumanoidRigType.R6 then
            local cm = inst:FindFirstChildOfClass("CharacterMesh")
            if cm then cm:Clone().Parent = character end
        elseif inst.Name == "R15" and humanoid.RigType == Enum.HumanoidRigType.R15 then
            local cm = inst:FindFirstChildOfClass("CharacterMesh")
            if cm then cm:Clone().Parent = character end
        end
    end

    if head then
        local faceInModel = appearanceModel:FindFirstChild("face") or appearanceModel:FindFirstChild("Face")
        if faceInModel and faceInModel:IsA("Decal") then
            faceInModel:Clone().Parent = head
        elseif not head:FindFirstChild("face") then
            local decal = Instance.new("Decal")
            decal.Face = Enum.NormalId.Front
            decal.Name = "face"
            decal.Texture = "rbxasset://textures/face.png"
            decal.Parent = head
        end
    end

    pcall(function()
        appearanceModel:Destroy()
    end)

    return finish(true)
end

SkinChanger_SaveCurrent = function()
    local userIdNum = tonumber(SkinChanger_UserId)
    if not userIdNum then
        SkinChanger_Notify("Disguise 저장 실패", "UserId를 숫자로 입력하세요!")
        return
    end

    local ok, name = pcall(function()
        return Players:GetNameFromUserIdAsync(userIdNum)
    end)
    if not ok or not name then
        name = "User_" .. tostring(userIdNum)
    end

    SkinChanger_Saved[name] = userIdNum
    SkinChanger_SaveToFile()
    SkinChanger_Notify("Disguise 저장됨", name .. "(" .. userIdNum .. ") 저장 완료!")
end

local function SkinChanger_ReapplyOnSpawn(character)
    if not SynexAlive() then
        return
    end
    local activeId = SkinChanger_ActiveId or tonumber(SkinChanger_UserId)
    if not activeId or not character then
        return
    end

    task.spawn(function()
        if not SynexAlive() then
            return
        end
        local humanoid = character:WaitForChild("Humanoid", 10)
        if not humanoid then
            return
        end
        character:WaitForChild("HumanoidRootPart", 10)

        -- Wait for default appearance so ApplyDescription sticks after respawn
        pcall(function()
            if LocalPlayer.CharacterAppearanceLoaded then
                if not LocalPlayer:HasAppearanceLoaded() then
                    LocalPlayer.CharacterAppearanceLoaded:Wait()
                end
            end
        end)
        task.wait(0.25)

        if not SynexAlive() then
            return
        end
        if LocalPlayer.Character ~= character then
            return
        end
        if humanoid.Health <= 0 then
            return
        end

        SkinChanger_Apply(activeId, nil, true)
    end)
end

SkinChanger_LoadFromFile()

