-- Detect real HP drops so every hit shows damage (any fire path)
local Ragebot_HealthWatch = {}
local Ragebot_LastDmgClock = {}
local function Ragebot_PollHitDamage()
    if not Ragebot_Enabled then
        Ragebot_HealthWatch = {}
        return
    end
    local now = tick()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if hum then
                local key = p.UserId
                local prev = Ragebot_HealthWatch[key]
                local nowHp = hum.Health
                if prev ~= nil and nowHp < prev - 0.25 then
                    local last = Ragebot_LastDmgClock[key] or 0
                    if now - last > 0.05 then
                        Ragebot_LastDmgClock[key] = now
                        ShowRageDamage(prev - nowHp, p.Name, p.Character)
                    end
                end
                Ragebot_HealthWatch[key] = nowHp
            end
        end
    end
end

local function GetEquippedWeapon()
    local myChar = LocalPlayer.Character
    if not myChar then return nil end

    -- 1) Standard Roblox Tool on character
    local tool = myChar:FindFirstChildOfClass("Tool")
    if tool then return tool end
    for _, child in ipairs(myChar:GetChildren()) do
        if child:IsA("Tool") then
            return child
        end
    end

    -- 2) Nested / viewmodel-style gun (Hitmarker / WeaponHandle anywhere under character)
    for _, inst in ipairs(myChar:GetDescendants()) do
        if inst:IsA("Tool") then
            return inst
        end
        if inst.Name == "Hitmarker" or inst.Name == "WeaponHandle" or inst.Name == "GunScript" then
            local model = inst.Parent
            while model and model ~= myChar do
                if model:IsA("Tool") or model:IsA("Model") then
                    return model
                end
                model = model.Parent
            end
            return inst.Parent
        end
    end

    -- 3) Backpack tool marked equipped (custom inventories)
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, t in ipairs(backpack:GetChildren()) do
            if t:IsA("Tool") then
                if t:GetAttribute("Equipped") == true
                    or t:GetAttribute("Equipped") == 1
                    or t:FindFirstChild("Equipped")
                then
                    return t
                end
            end
        end
    end

    return nil
end

